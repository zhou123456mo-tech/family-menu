# ========================================
# 家用菜单系统 - 环境变量配置模板
# ========================================
# 复制此文件为 .env.local 或运行 ./scripts/setup-dev.sh 自动配置

# ========================================
# 本地开发 (SQLite)
# ========================================
DATABASE_URL="file:./prisma/dev.db"

# ========================================
# 生产环境 (Turso)
# ========================================
# 1. 安装 Turso CLI: curl -sSfL https://get.turso.tech/install.sh | bash
# 2. 注册: turso auth signup
# 3. 创建数据库: turso db create home-menu
# 4. 获取连接信息: turso db show home-menu
# 5. 创建 token: turso db tokens create home-menu

# Turso 数据库 URL (从 turso db show 获取)
# TURSO_DATABASE_URL="libsql://home-menu-xxx.turso.io"

# Turso 认证 Token (从 turso db tokens create 获取)
# TURSO_AUTH_TOKEN="eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9..."

# ========================================
# NextAuth.js 配置
# ========================================
# 用于 JWT 签名，生成命令: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# 应用访问地址
# 开发环境: http://localhost:3000
# 生产环境: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
